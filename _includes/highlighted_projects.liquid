<div class="highlighted-projects">
  {% assign projects = site.data.highlighted_projects %}
  {% if projects %}
    <div class="row row-cols-1 row-cols-md-2 g-4">
      {% for project in projects %}
        <div class="col">
          <div class="card h-100">
            <div class="card-body">
              <div class="project-header">
                <h5 class="card-title">
                  <a href="{{ project.github }}" target="_blank" rel="noopener noreferrer">{{ project.name }}</a>
                </h5>
                {% if project.thumbnail %}
                  <div class="project-icon">
                    {% include figure.liquid loading="eager" path=project.thumbnail alt=project.name class="img-fluid" %}
                  </div>
                {% endif %}
              </div>
              <p class="card-text">{{ project.description }}</p>
              <div class="project-links">
                <a href="{{ project.github }}" class="btn btn-sm z-depth-0" role="button" target="_blank" rel="noopener noreferrer">
                  <i class="fa-brands fa-github"></i> GitHub
                </a>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>
