<div class="highlighted-projects">
  {% assign projects = site.data.highlighted_projects %}
  {% if projects %}
    {% assign work_projects = projects | where_exp: "p", "p.personal != true" %}
    {% assign personal_projects = projects | where_exp: "p", "p.personal == true" %}

    {% assign personal_ids = "" %}
    {% for project in personal_projects %}{% assign personal_ids = personal_ids | append: "personal-highlighted-" | append: forloop.index | append: " " %}{% endfor %}

    <!-- Work + personal share one masonry grid. Personal cards sit inline,
         hidden until the toggle reveals them, so they fill in right after the
         work cards; the toggle trails along to whatever the last cell becomes. -->
    <div class="projects-masonry">
      {% for project in work_projects %}
        {% include highlighted_project_card.liquid %}
      {% endfor %}
      {% for project in personal_projects %}
        {% capture pid %}personal-highlighted-{{ forloop.index }}{% endcapture %}
        {% include highlighted_project_card.liquid extra_class="js-personal" id=pid %}
      {% endfor %}

      {% if personal_projects.size > 0 %}
        <div class="projects-toggle-cell">
          <button
            type="button"
            id="toggle-personal-highlighted"
            class="projects-toggle"
            aria-expanded="false"
            aria-controls="{{ personal_ids | strip }}"
          >
            <span class="toggle-label">Show personal</span>
            <span class="toggle-count">{{ personal_projects.size }}</span>
            <i class="fa-solid fa-chevron-down toggle-chevron" aria-hidden="true"></i>
          </button>
        </div>
      {% endif %}
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".project-stats[data-repo]").forEach(function (el) {
          var repo = el.getAttribute("data-repo");
          fetch("https://api.github.com/repos/" + repo)
            .then(function (res) { return res.json(); })
            .then(function (data) {
              if (data.stargazers_count !== undefined) {
                el.querySelector(".star-count").textContent = data.stargazers_count;
              }
              if (data.watchers_count !== undefined) {
                el.querySelector(".watcher-count").textContent = data.subscribers_count || data.watchers_count;
              }
            })
            .catch(function () {});
        });

        var btn = document.getElementById("toggle-personal-highlighted");
        var grid = document.querySelector(".highlighted-projects");
        if (btn && grid) {
          var label = btn.querySelector(".toggle-label");
          var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          var hideTimer;
          btn.addEventListener("click", function () {
            var expanded = btn.getAttribute("aria-expanded") === "true";
            window.clearTimeout(hideTimer);
            if (expanded) {
              btn.setAttribute("aria-expanded", "false");
              if (label) label.textContent = "Show personal";
              // fade the cards out, then drop them from the grid once they settle
              grid.classList.remove("personal-in");
              if (reduce) {
                grid.classList.remove("personal-open");
              } else {
                hideTimer = window.setTimeout(function () {
                  if (btn.getAttribute("aria-expanded") === "false") grid.classList.remove("personal-open");
                }, 500);
              }
            } else {
              btn.setAttribute("aria-expanded", "true");
              if (label) label.textContent = "Hide personal";
              // place the cards in the grid (transparent), then fade them in
              grid.classList.add("personal-open");
              requestAnimationFrame(function () {
                requestAnimationFrame(function () {
                  grid.classList.add("personal-in");
                });
              });
            }
          });
        }
      });
    </script>

    <noscript>
      <style>
        /* Without JS there is no toggle, so just show everything, un-hidden.
           Cards are flex (Bootstrap .card), so restore flex, not block. */
        .highlighted-projects .js-personal {
          display: flex !important;
          opacity: 1 !important;
          transform: none !important;
        }
        .highlighted-projects .projects-toggle-cell {
          display: none;
        }
      </style>
    </noscript>
  {% endif %}
</div>
